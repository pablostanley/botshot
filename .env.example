# Vercel Postgres (Neon) — added automatically when you link a Vercel Postgres store
DATABASE_URL=postgresql://...

# Vercel Blob — added automatically when you link a Vercel Blob store
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Resend — for magic link emails
RESEND_API_KEY=re_...

# App URL
NEXT_PUBLIC_APP_URL=https://botshot.dev
